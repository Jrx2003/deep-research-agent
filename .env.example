# Deep Research Agent - Environment Configuration

# ============================================
# Required API Keys
# ============================================

# OpenAI (required)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Optional API Keys
# ============================================

# SerpAPI - for Google search (optional but recommended)
SERPAPI_API_KEY=your_serpapi_key_here

# LangSmith - for tracing and observability (optional)
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=deep-research-agent
LANGCHAIN_TRACING_V2=true

# ============================================
# Model Configuration
# ============================================

# Default models for each tier
MODEL_TIER_LIGHT=gpt-4o-mini
MODEL_TIER_MEDIUM=gpt-4o
MODEL_TIER_STRONG=o1-preview

# Fallback models
MODEL_FALLBACK_LIGHT=claude-3-haiku-20240307
MODEL_FALLBACK_MEDIUM=claude-3-sonnet-20241022
MODEL_FALLBACK_STRONG=claude-3-opus-20240229

# ============================================
# Research Configuration
# ============================================

# Maximum iterations for feedback loop
MAX_ITERATIONS=3

# Search configuration
SEARCH_RESULTS_PER_QUERY=5
SEARCH_DEPTH=normal  # shallow, normal, deep

# Rate limiting
REQUESTS_PER_MINUTE=60

# ============================================
# Storage Configuration
# ============================================

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Output directory
OUTPUT_DIR=./output

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json, text
